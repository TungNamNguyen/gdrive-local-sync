# Copy to .env and fill in.  (cp .env.example .env)

# --- Required -----------------------------------------------------------------
# Linux examples: /media/tung/Seagate   |   /mnt/seagate
SEAGATE_MOUNT=

# UI login password. Empty = NO login gate (a warning is shown).
APP_PASSWORD=

# --- Optional -----------------------------------------------------------------
# Drive root folder to compare against: "root" = the entire My Drive,
# or e.g. "Backup/Seagate".
DRIVE_ROOT_FOLDER=root

# Subfolder inside the mounted drive preselected in the UI (changeable there;
# empty = the whole drive).
SEAGATE_SUBDIR=googledrive

# Number of files transferred in parallel during sync (default 4; 1 = sequential).
SYNC_WORKERS=4

# Display timezone (logs/history). Example: Asia/Ho_Chi_Minh
TZ=Asia/Ho_Chi_Minh

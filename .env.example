# Copy to .env and fill in.  (cp .env.example .env)

# --- Bat buoc ---------------------------------------------------------------
# Host path cua o Seagate (bind-mount vao /data/seagate trong container).
# Vi du Linux: /media/tung/Seagate   |   /mnt/seagate
SEAGATE_MOUNT=/media/tung/Seagate

# Mat khau dang nhap giao dien. De trong = KHONG co cong dang nhap (canh bao).
APP_PASSWORD=doi-mat-khau-nay

# --- Tuy chon ---------------------------------------------------------------
# Thu muc goc tren Drive de doi chieu: "root" = toan bo My Drive,
# hoac vi du "Backup/Seagate".
DRIVE_ROOT_FOLDER=root

# So file truyen song song khi dong bo (mac dinh 4; dat 1 = tuan tu).
SYNC_WORKERS=4

# Mui gio hien thi (log/lich su). Vi du: Asia/Ho_Chi_Minh
TZ=Asia/Ho_Chi_Minh
